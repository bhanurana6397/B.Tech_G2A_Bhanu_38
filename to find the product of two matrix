#include <stdio.h>
#include <stdlib.h>
int main ()
{
    int a[10][10];
    int b[10][10];
    int c[10][10];
    int i,j,r,c2,r1,c1,k;
    printf("enter the no of rows and column of matrix A\n");
    scanf("%d%d",&r,&c2);
     printf("enter the no of rows and column of matrix B\n");
    scanf("%d%d",&r1,&c1);
    if (c2!=r1)
    {
        printf("multiply not possible");
        exit(0);
    }
    printf("Enter matrix A\n");
    for (i=0;i<r;i++)
    {
        for (j=0;j<c2;j++)
        {
            scanf("%d",&a[i][j]);
        }
    }
    printf("Enter matrix B\n");
    for (i=0;i<r1;i++)
    {
        for (j=0;j<c1;j++)
        {
            scanf("%d",&b[i][j]);
        }
    }
    printf("The multiplication of two matrix is\n");
    for (i=0;i<r;i++){
        for (j=0;j<c1;j++){
            c[i][j]=0;
            for ( k=0;k<c2;k++){
                c[i][j]=c[i][j]+a[i][k]*b[k][j];
            }
            printf("%d ",c[i][j]);
           
        }
         printf("\n");
    }
    return 0;
}
