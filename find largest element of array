#include <stdio.h>

int main()
{
    int a[100],i,n,c;
    printf("enter the no of elements \n");
    scanf("%d",&n);
    printf("enter the elements of array\n");
    for (i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    for(i=0;i<n-1;i++)
    {
        if(a[i]>=a[i+1])
        {
            c=a[i+1];
            a[i+1]=a[i];
            a[i]=c;
            
        }
    }
