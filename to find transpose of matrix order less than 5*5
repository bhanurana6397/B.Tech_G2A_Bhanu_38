#include <stdio.h>
int main ()
{
    int a[5][5];
    int i,j,r,c;
    printf("enter the no of rows and column\n");
    scanf("%d%d",&r,&c);
    printf("Enter matrix\n");
    for (i=0;i<r;i++)
    {
        for (j=0;j<c;j++)
        {
            scanf("%d",&a[i][j]);
        }
    }
    printf("The transpose of matrix is\n");
    for (i=0;i<c;i++){
        for (j=0;j<r;j++){
            printf("%d  ",a[j][i]);
        }
        printf("\n");
    }
    return 0;
}
